{
  "name": "ts-invoice-generator",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*", "cli"],
  "scripts": {
    "dev": "npm run dev --workspace=@invoice/app",
    "build": "npm run build --workspace=@invoice/app",
    "dev:app": "npm run dev --workspace=@invoice/app",
    "build:app": "npm run build --workspace=@invoice/app",
    "dev:web": "npm run dev --workspace=@invoice/web",
    "dev:cli": "cd cli && bun run src/index.ts",
    "build:cli": "cd cli && bun build src/index.ts --compile --outfile invoice",
    "build:shared": "npm run build --workspace=@invoice/shared",
    "build:api": "npm run build --workspace=@invoice/api",
    "build:web": "npm run build --workspace=@invoice/web",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf packages/*/node_modules packages/*/dist cli/node_modules node_modules"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
